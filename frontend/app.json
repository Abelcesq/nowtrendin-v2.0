{
  "expo": {
    "name": "Now TrendIn",
    "slug": "now-trendin-20",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "scheme": "nowtrendin",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "eas": {
        "projectId": "ef045a1d-05df-4ab5-b474-508c412ae420"
      }
    },
    "owner": "now-trendin",
    "plugins": [
      "expo-secure-store",
      "expo-router"
    ]
  }
}
