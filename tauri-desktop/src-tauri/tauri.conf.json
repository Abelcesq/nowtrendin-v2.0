{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Now TrendIn",
  "version": "2.0.0",
  "identifier": "com.nowtrendin.desktop",
  "build": {
    "frontendDist": "../../web-terminal/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Now TrendIn Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
