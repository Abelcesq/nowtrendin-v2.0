# .env.example — Engine (nowtrendin-v2-engine)
# Copy to .env for local development. Never commit .env.
# For Heroku values, see: heroku config -a nowtrendin-v2-engine
# Full descriptions: docs/ENV_REFERENCE.md

# Infrastructure
DATABASE_URL=
PORT=8000
INTERNAL_API_KEY=
ADMIN_API_KEY=

# AI / Grading
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
AI_GRADE_CLAUDE_MODEL=claude-sonnet-4-6
AI_GRADE_PPLX_MODEL=sonar

# Social signals
X_BEARER_TOKEN=
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=nowtrendin/1.0
APIFY_TOKEN=
APIFY_REALTIME_ACTOR=
APIFY_TRENDS_ACTOR=
MASTODON_INSTANCE=mastodon.social

# News / Media
NEWSAPI_ORG_KEY=
NEWSAPI_AI_KEY=
NEWSDATA_IO_KEY=
CURRENTS_API_KEY=
CURRENTS_DAILY_CAP=900
GUARDIAN_API_KEY=
DEVTO_API_KEY=
HASHNODE_TOKEN=
GITHUB_TOKEN=
BLOGGER_API_KEY=

# Market / Financial
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
FINRA_API_KEY=
WHALEWISDOM_SHARED_KEY=
WHALEWISDOM_SECRET_KEY=
RAPIDAPI_YF_KEY=
FRED_API_KEY=

# Search / Discovery
SERPAPI_KEY=
GOOGLE_TRENDS_ENABLED=true

# Pipeline tuning (safe defaults — only set to override)
COLLECT_INTERVAL_MIN=360
VELOCITY_RETENTION_DAYS=90
CATCHALL_MIN_SOURCES=2
X_MONTHLY_POST_BUDGET=12000
DUAL_PATHWAY=true
SCORE_WITH_COLLECT=true
MAINSTREAM_NEWS_ENABLED=true
