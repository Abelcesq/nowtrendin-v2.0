# .env.example — Backend (nowtrendin-backend)
# Copy to .env for local development. Never commit .env.
# For Heroku values, see: heroku config -a nowtrendin-backend
# Full descriptions: docs/ENV_REFERENCE.md

# Django
SECRET_KEY=
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings

# Database
DATABASE_URL=

# Engine URL (always v2 engine)
GRADIENT_API=https://nowtrendin-v2-engine-edcb10d44f91.herokuapp.com
INTERNAL_API_KEY=

# Google OAuth
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# Push notifications (deferred — requires custom dev client)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Gunicorn (Heroku sets this automatically)
PORT=8000
WEB_CONCURRENCY=2
